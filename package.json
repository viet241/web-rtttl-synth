{
    "name": "web-rtttl-synth",
    "version": "0.1.0",
    "description": "RTTTL parser and Web Audio synth playback library for browsers.",
    "homepage": "https://github.com/viet241/web-rtttl-synth#readme",
    "bugs": {
        "url": "https://github.com/viet241/web-rtttl-synth/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/viet241/web-rtttl-synth.git"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "rtttl",
        "web-audio",
        "synth",
        "audio",
        "typescript"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite --port=3000 --host=0.0.0.0",
        "build": "vite build",
        "build:lib": "npm run clean && vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
        "preview": "vite preview",
        "clean": "rm -rf dist",
        "lint": "tsc --noEmit",
        "test": "vitest run"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.1.14",
        "@types/node": "^22.14.0",
        "@vitejs/plugin-react": "^5.0.4",
        "lucide-react": "^0.546.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.14.1",
        "react-window": "^2.2.7",
        "tailwindcss": "^4.1.14",
        "typescript": "~5.8.2",
        "vite": "^6.2.0",
        "vitest": "^3.2.4"
    }
}
